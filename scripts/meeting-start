#!/bin/sh

# Switch WF-1000XM5 from A2DP to HFP profile and start a minutes recording.
# HFP enables the BT microphone at the cost of audio quality (narrowband mono).
# Usage: meeting-start [optional title]

# AIDEV-NOTE: BT card ID is stable for this paired device (MAC 80:99:E7:69:A6:7C).
# Update if headset is re-paired or MAC changes.
BT_CARD="bluez_card.80_99_E7_69_A6_7C"
BT_MIC="WF-1000XM5"
HFP_PROFILE="headset-head-unit"

notify() {
    if command -v notify-send >/dev/null 2>&1; then
        notify-send -u low "$1" "$2" -t 3000 2>/dev/null || true
    fi
    echo "$1: $2"
}

# Check headset is connected
if ! pactl list cards short 2>/dev/null | grep -q "$BT_CARD"; then
    echo "Error: $BT_MIC not found. Is it connected?" >&2
    exit 1
fi

# Switch to HFP (enables microphone)
if ! pactl set-card-profile "$BT_CARD" "$HFP_PROFILE" 2>/dev/null; then
    echo "Error: failed to switch to HFP profile." >&2
    exit 1
fi

notify "🎙️ Meeting starting" "Switched to HFP — mic active"

# Start recording: --call captures both mic + system audio
if [ -n "$1" ]; then
    exec minutes record --call --source "$BT_MIC" --title "$*"
else
    exec minutes record --call --source "$BT_MIC"
fi
