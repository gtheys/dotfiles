# reload zsh config
alias reload!='source $ZDOTDIR/.zshrc'

# Filesystem aliases
alias ..='cd ..'
alias ...='cd ../..'
alias ....="cd ../../.."
alias .....="cd ../../../.."

# Helpers
alias grep='grep --color=auto'
alias df='df -h' # disk free, in Gigabytes, not bytes
alias du='du -h -c' # calculate disk usage for a folder

alias lpath='echo $PATH | tr ":" "\n"' # list the PATH separated by new lines

# tmux aliases
alias ta='tmux attach'
alias tls='tmux ls'
alias tat='tmux attach -t'
alias tns='tmux new-session -s'

# AIDEV-NOTE: macOS aliases (ios, hidedesktop/showdesktop) removed — migrated to Arch.
# Find them in the keep-windows branch if needed again.

# Recursively delete `.DS_Store` files
alias cleanup="find . -name '*.DS_Store' -type f -ls -delete"
# remove broken symlinks
alias clsym="find -L . -name . -o -type d -prune -o -type l -exec rm {} +"


# AIDEV-NOTE: use eza (active exa fork) if available, fall back to ls
if [[ -x "$(command -v eza)" ]]; then
  alias ll="eza --icons --git --long"
  alias l="eza --icons --git --all --long"
else
  alias l="ls -lah --color"
  alias ll="ls -lFh --color"
fi
alias la="ls -AF --color"
alias lld="ls -l | grep ^d"
alias rmf="rm -rf"

# AIDEV-NOTE: macOS aliases and hyprctl aliases (lhz/hhz) removed — on niri now.
# Find them in git history if needed.

# Show latest Arch Linux news before upgrading
arch_news_check() {
    echo "🔔 Latest Arch Linux news:"
    # AIDEV-NOTE: --max-time prevents hang when offline; --fail avoids piping 404 HTML through grep.
    curl --max-time 5 --fail --silent --show-error https://archlinux.org/news/ \
      | grep -Eo 'href="/news/[^"]+"' \
      | cut -d'"' -f2 \
      | head -n 5 \
      | sed 's|^|https://archlinux.org|'

    echo
}

alias pacnews="arch_news_check"

# AIDEV-NOTE: pi needs node >=22 (undici markAsUncloneable) regardless of the current
# project's .mise.toml. Resolve the highest installed node via mise so this survives
# node version bumps (previously hardcoded to 23.11.1).
pi() {
    local pi_dir="$HOME/Code/personal/pi-my-rifle-ext"
    local cli="$pi_dir/node_modules/@earendil-works/pi-coding-agent/dist/cli.js"
    local node_bin="$HOME/.local/share/mise/installs/node/$(mise latest --installed node)/bin/node"
    [[ -x "$node_bin" ]] || node_bin="node"
    "$node_bin" "$cli" "$@"
}
