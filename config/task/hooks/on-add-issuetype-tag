#!/usr/bin/env python3
# AIDEV-NOTE: Taskwarrior on-add hook â€” translates jiraissuetype UDA into a tag.
# Maps: Bugâ†’bug, Storyâ†’story, Taskâ†’task, Sub-taskâ†’subtask
# Runs on every task add; no-ops when jiraissuetype is absent.
import json
import sys

ISSUETYPE_TAG_MAP = {
    "Bug": "bug",
    "Story": "story",
    "Task": "task",
    "Sub-task": "subtask",
    "Epic": "epic",
}

task = json.load(sys.stdin)

issue_type = task.get("jiraissuetype")
if issue_type:
    tag = ISSUETYPE_TAG_MAP.get(issue_type, issue_type.lower().replace(" ", "_").replace("-", "_"))
    tags = task.get("tags", [])
    if tag not in tags:
        tags.append(tag)
        task["tags"] = tags

print(json.dumps(task))
sys.exit(0)
